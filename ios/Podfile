# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# Import permissions setup
require_relative '../node_modules/react-native-permissions/scripts/setup'

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'SeaBuddy' do
  config = use_native_modules!
  use_frameworks! :linkage => :static
  $RNFirebaseAsStaticFramework = true

  # 🔧 Force all Firebase pods to same version
  $FirebaseSDKVersion = '11.11.0'
  pod 'Firebase/CoreOnly', $FirebaseSDKVersion
  pod 'Firebase/Auth', $FirebaseSDKVersion
  pod 'Firebase/Database', $FirebaseSDKVersion
  pod 'Firebase/Messaging', $FirebaseSDKVersion
  pod 'Firebase/Crashlytics', $FirebaseSDKVersion
  pod 'Firebase/Analytics', $FirebaseSDKVersion
  pod 'Firebase/Firestore', $FirebaseSDKVersion
  
  # Set up permissions explicitly
  setup_permissions([
    # Use the exact permission name as required by react-native-permissions
    'Camera',
    'LocationWhenInUse',
    'PhotoLibrary',
    'PhotoLibraryAddOnly',
    'Notifications'
  ])
  
  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'SeaBuddyTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
  end
end
