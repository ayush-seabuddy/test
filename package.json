{
  "name": "seabuddy",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:local": "APP_ENV=local expo start",
    "start:preview": "APP_ENV=staging expo start",
    "start:development": "APP_ENV=development expo start",
    "start:production": "APP_ENV=production expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "android:local": "APP_ENV=local expo start --android",
    "android:preview": "APP_ENV=staging expo start --android",
    "android:development": "APP_ENV=development expo start --android",
    "android:production": "APP_ENV=production expo start --android",
    "ios:local": "APP_ENV=local expo start --ios",
    "ios:preview": "APP_ENV=staging expo start --ios",
    "ios:development": "APP_ENV=development expo start --ios",
    "ios:production": "APP_ENV=production expo start --ios",
    "ios:setup": "npm i --legacy-peer-deps && npm ci && cd ./ios && pod deintegrate && pod install || { echo 'iOS setup failed. Please check the error above.'; exit 1; }",
    "web": "expo start --web",
    "eas:build:android:preview": "eas build --platform android --profile preview",
    "eas:build:android:preview:local": "eas build --platform android --profile preview --local",
    "eas:build:android:development": "eas build --platform android --profile development",
    "eas:build:android:development:local": "eas build --platform android --profile development --local",
    "eas:build:android:production": "eas build --platform android --profile production",
    "eas:build:android:production:local": "eas build --platform android --profile production --local",
    "eas:build:ios:preview": "eas build --platform ios --profile preview",
    "eas:build:ios:preview:local": "eas build --platform ios --profile preview --local",
    "eas:build:ios:development": "eas build --platform ios --profile development",
    "eas:build:ios:development:local": "eas build --platform ios --profile development --local",
    "eas:build:ios:production": "eas build --platform ios --profile production",
    "eas:build:ios:production:local": "eas build --platform ios --profile production --local",
    "eas:build:all:preview": "eas build --platform all --profile preview",
    "eas:build:all:preview:local": "eas build --platform all --profile preview --local",
    "eas:build:all:development": "eas build --platform all --profile development",
    "eas:build:all:development:local": "eas build --platform all --profile development --local",
    "eas:build:all:production": "eas build --platform all --profile production",
    "eas:build:all:production:local": "eas build --platform all --profile production --local",
    "eas:submit:android:production": "eas submit --platform android --profile production",
    "eas:submit:ios:production": "eas submit --platform ios --profile production",
    "lint": "expo lint",
    "postinstall": "patch-package"
