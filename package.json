{
  "name": "seabuddy",
  "main": "expo-router/entry",
  "version": "1.1.1",

    "scripts": {
      "start": "expo start",
      "start:clear": "expo start -c",
      "start:dev": "NODE_ENV=development expo start --dev-client",
      "start:preview": "NODE_ENV=preview expo start",
      "start:prod": "NODE_ENV=production expo start",

      "android:dev": "NODE_ENV=development APP_VARIANT=development expo run:android",
      "android:preview": "NODE_ENV=preview APP_VARIANT=preview expo run:android",
      "android:prod": "NODE_ENV=production APP_VARIANT=production expo run:android",

      "ios:dev": "NODE_ENV=development expo run:ios",
      "ios:preview": "NODE_ENV=preview expo run:ios",
      "ios:prod": "NODE_ENV=production expo run:ios",

      "build:dev:android": "NODE_ENV=development eas build --profile development pnp--platform android",
      "build:dev:ios": "NODE_ENV=development eas build --profile development --platform ios",

      "build:preview:android": "NODE_ENV=preview eas build --profile preview --platform android",
      "build:preview:ios": "NODE_ENV=preview eas build --profile preview --platform ios",

      "build:preview:android:local": "NODE_ENV=preview eas build --profile preview --platform android --local",
      "build:preview:ios:local": "NODE_ENV=preview eas build --profile preview --platform ios --local",

      "build:prod:android": "NODE_ENV=production eas build --profile production --platform android",
      "build:prod:ios": "NODE_ENV=production eas build --profile production --platform ios",

      "update:preview": "eas update --branch preview",
      "update:production": "eas update --branch production",

      "prebuild": "expo prebuild",
      "lint": "expo lint",
      "lint:fix": "expo lint --fix",
      "format": "prettier . --write",
      "typecheck": "tsc --noEmit",
      "postinstall": "patch-package",

      "android": "expo run:android",
      "ios": "expo run:ios"
    },
