{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "channel": "development",
      "distribution": "internal",
      "autoIncrement": true
    },

    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },

    "preview": {
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "APP_ENV": "staging",
        "API_URL": "$API_URL",
        "SOCKET_URL": "$SOCKET_URL"
      },
      "android": {
        "buildType": "apk",
        "distribution": "internal"
      },
      "ios": {
        "buildConfiguration": "Release",
        "simulator": true
      }
    },

    "production": {
      "channel": "production",
      "distribution": "store",
      "autoIncrement": true,
      "android": {
        "gradleCommand": ":app:bundleRelease"
      },
      "ios": {
        "buildConfiguration": "Release",
        "autoIncrement": "buildNumber"
      },
      "env": {
        "APP_ENV": "production",
        "API_URL": "$API_URL",
        "SOCKET_URL": "$SOCKET_URL"
      }
    }
  },

  "submit": {
    "production": {
      "ios": {},
      "android": {
        "track": "internal"
      }
    },
    "preview": {
      "ios": {},
      "android": {
        "track": "internal"
      }
    }
  }
}
